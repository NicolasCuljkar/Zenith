# Server
PORT=3001
NODE_ENV=development

# JWT — use a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# Database path
# Local:      ./database/zenith.db
# Railway:    /data/zenith.db  (persistent volume mounted at /data)
DB_PATH=./database/zenith.db

# Production only — your Railway public URL (for CORS)
# Example: https://zenith-production.up.railway.app
FRONTEND_URL=

# Bridge API — Open Banking (bridgeapi.io)
# Créer un compte sur https://bridgeapi.io → Dashboard → API Credentials
BRIDGE_CLIENT_ID=
BRIDGE_CLIENT_SECRET=

# Plaid (Open Banking)
# Compte sur https://dashboard.plaid.com → Team Settings → Keys
# PLAID_ENV : sandbox (test) | development (vrai comptes, gratuit jusqu'à 100 items) | production
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
